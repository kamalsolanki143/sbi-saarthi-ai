# ============================================================
# SAARTHI AI — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# ============================================================

# --- App ---
APP_NAME="SAARTHI AI"
APP_ENV=development                 # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secret_key_here

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# --- Sarvam AI (STT / TTS / Translation) ---
SARVAM_API_KEY=your_sarvam_api_key_here

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL_SECONDS=3600             # 1 hour session TTL

# --- ChromaDB (vector memory) ---
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=saarthi_customer_memory

# --- Database (flat-file paths) ---
DATABASE_DIR=./database

# --- Confidence Threshold ---
CONFIDENCE_THRESHOLD=0.85

# --- MPIN (demo) ---
DEFAULT_DEMO_MPIN=1234

# --- Tesseract OCR ---
TESSERACT_CMD=/usr/bin/tesseract
